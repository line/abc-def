{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^@line/abc-def-"],
      "enabled": false
    }
  ],
  "minimumReleaseAge": "3 days",
  "updateInternalDeps": true,
  "rangeStrategy": "bump",
  "automerge": true
}
