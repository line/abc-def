{
  "name": "@line/abc-def-react",
  "version": "2.0.0",
  "description": "React components for the ABC Def design system",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/line/abc-def.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/line/abc-def/issues"
  },
  "homepage": "https://github.com/line/abc-def/tree/main/packages/react#readme",
  "keywords": [
    "abc-def",
    "design-system",
    "react",
    "components",
    "tailwindcss"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "scripts": {
    "dev": "tsup --config tsup.config.ts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "build": "tsup --config tsup.config.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "catalog:",
    "lucide-react": "catalog:",
    "next-themes": "catalog:",
    "radix-ui": "^1.6.1",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "^4.12.0",
    "sonner": "catalog:",
    "tailwind-merge": "catalog:",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@line/abc-def-eslint-config": "workspace:^",
    "@line/abc-def-prettier-config": "workspace:^",
    "@line/abc-def-styles": "workspace:*",
    "@line/abc-def-tsconfig": "workspace:^",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@line/abc-def-prettier-config"
}
