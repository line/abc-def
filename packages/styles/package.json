{
  "name": "@abc-def/styles",
  "version": "0.0.1",
  "description": "Shared design tokens and Tailwind CSS v4 styling contract for the abc-def design system",
  "license": "Apache-2.0",
  "type": "module",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "exports": {
    "./css": "./src/index.css",
    "./semantic": "./src/semantic.css",
    "./components": "./src/components/index.css"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@line/abc-def-eslint-config": "workspace:^",
    "@line/abc-def-prettier-config": "workspace:^",
    "@line/abc-def-tsconfig": "workspace:^",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tailwindcss": "catalog:"
  },
  "prettier": "@line/abc-def-prettier-config"
}
